---
import BaseLayout from './BaseLayout.astro';
import PostHeader from '../components/blog/PostHeader.astro';
import TableOfContents from '../components/blog/TableOfContents.astro';
import AuthorBio from '../components/blog/AuthorBio.astro';
import CTABanner from '../components/blog/CTABanner.astro';
import ShareButtons from '../components/blog/ShareButtons.astro';
import RelatedPosts from '../components/blog/RelatedPosts.astro';
import { generateArticleJsonLd } from '../utils/seo';
import type { CollectionEntry } from 'astro:content';
import { CATEGORY_LABELS, SITE_URL } from '../config';

interface Props {
  post: CollectionEntry<'blog'>;
  headings: { depth: number; slug: string; text: string }[];
  readingTime: number;
  relatedPosts: CollectionEntry<'blog'>[];
}

const { post, headings, readingTime, relatedPosts } = Astro.props;
const { title, description, publishDate, updatedDate, category, image, author, tags } = post.data;

const articleUrl = `${SITE_URL}/blog/${post.slug}/`;
const articleJsonLd = generateArticleJsonLd({
  title,
  description,
  publishDate,
  updatedDate,
  image: image.src,
  url: articleUrl,
  authorName: author.name,
});
---

<BaseLayout
  title={`${title} | Make It Global`}
  description={description}
  ogImage={image.src}
  ogType="article"
  articleMeta={{
    publishedTime: publishDate.toISOString(),
    modifiedTime: updatedDate?.toISOString(),
    section: CATEGORY_LABELS[category],
    tags,
  }}
>
  <script type="application/ld+json" set:html={articleJsonLd} />

  <main id="main-content" class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8 py-8 md:py-12">
    <div class="lg:grid lg:grid-cols-[1fr_220px] lg:gap-12">
      <article class="min-w-0">
        <PostHeader
          title={title}
          description={description}
          publishDate={publishDate}
          updatedDate={updatedDate}
          category={category}
          image={image}
          author={author}
          readingTime={readingTime}
        />

        <div class="prose">
          <slot />
        </div>

        <CTABanner variant="contact" />

        <ShareButtons title={title} url={articleUrl} />

        <AuthorBio name={author.name} role={author.role} />

        <RelatedPosts posts={relatedPosts} />
      </article>

      <TableOfContents headings={headings} />
    </div>
  </main>
</BaseLayout>
