---
/**
 * ProcessSection Component - Light Pastel Theme
 *
 * Displays the 3-step turnkey process:
 * 1. You send your content
 * 2. We translate and validate
 * 3. You receive in 72h
 *
 * Features:
 * - Semantic HTML with ARIA landmarks
 * - Responsive design: 1 col mobile, 3 col desktop
 * - Reassurance message: "You don't have to manage anything"
 * - WCAG AA compliant color contrast
 */

import GeometricBackground from '../ui/GeometricBackground.astro';

interface Props {
  // No props needed for MVP - hard-coded content
}
---

<section
  id="process"
  aria-labelledby="process-heading"
  aria-label="Processus de travail"
  class="relative py-20 md:py-32 px-6 md:px-12 bg-white overflow-hidden"
>
  <!-- Geometric Background Animation -->
  <GeometricBackground intensity="medium" variant="teal" />

  <div class="relative z-10 max-w-7xl mx-auto">
    <!-- Section Heading -->
    <div class="text-center mb-16" data-reveal="fade-up">
      <h2 id="process-heading" class="text-3xl md:text-4xl lg:text-5xl font-bold text-text-heading text-center mb-4">
        Notre Processus Clé-en-Main
      </h2>
      <p class="text-lg text-text-muted">
        Un processus simple en 3 étapes
      </p>
    </div>

    <!-- 3-Step Process -->
    <div class="relative max-w-6xl mx-auto">
      <!-- Connection Line (Desktop only) -->
      <div class="hidden md:block absolute top-32 left-[15%] right-[15%] h-0.5 bg-gradient-to-r from-primary-200 via-primary-400 to-teal-300 process-line-animated" data-reveal aria-hidden="true"></div>

      <div class="grid grid-cols-1 md:grid-cols-3 gap-12 md:gap-8">

        <!-- Step 1 -->
        <div class="relative process-step">
          <div class="bg-white rounded-3xl shadow-card border border-neutral-100 p-8 card-hover" data-reveal="fade-up" data-reveal-delay="100">
            <!-- Number Badge -->
            <div class="flex justify-center mb-6">
              <div class="w-16 h-16 rounded-2xl bg-gradient-to-br from-primary-400 to-primary-500 flex items-center justify-center" data-reveal="number-pop">
                <span class="text-2xl font-bold text-white">1</span>
              </div>
            </div>

            <!-- Icon -->
            <div class="flex justify-center mb-6">
              <div class="w-14 h-14 rounded-xl bg-primary-50 border border-primary-100 flex items-center justify-center">
                <!-- Upload Icon -->
                <svg class="w-7 h-7 text-primary-500" fill="none" viewBox="0 0 24 24" stroke="currentColor" aria-hidden="true">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M7 16a4 4 0 01-.88-7.903A5 5 0 1115.9 6L16 6a5 5 0 011 9.9M15 13l-3-3m0 0l-3 3m3-3v12" />
                </svg>
              </div>
            </div>

            <!-- Content -->
            <h3 class="text-xl font-semibold text-text-heading mb-3 text-center">
              Transmission de vos contenus
            </h3>
            <p class="text-text-muted text-base text-center leading-relaxed">
              Envoyez vos fichiers dans leur format d'origine. Nous acceptons tous les formats sans conversion préalable.
            </p>
          </div>
        </div>

        <!-- Step 2 -->
        <div class="relative process-step">
          <div class="bg-white rounded-3xl shadow-card border border-neutral-100 p-8 card-hover" data-reveal="fade-up" data-reveal-delay="250">
            <!-- Number Badge -->
            <div class="flex justify-center mb-6">
              <div class="w-16 h-16 rounded-2xl bg-gradient-to-br from-primary-400 to-primary-500 flex items-center justify-center" data-reveal="number-pop" data-reveal-delay="200">
                <span class="text-2xl font-bold text-white">2</span>
              </div>
            </div>

            <!-- Icon -->
            <div class="flex justify-center mb-6">
              <div class="w-14 h-14 rounded-xl bg-primary-50 border border-primary-100 flex items-center justify-center">
                <!-- Process Icon (IA + Human) -->
                <svg class="w-7 h-7 text-primary-500" fill="none" viewBox="0 0 24 24" stroke="currentColor" aria-hidden="true">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9.663 17h4.673M12 3v1m6.364 1.636l-.707.707M21 12h-1M4 12H3m3.343-5.657l-.707-.707m2.828 9.9a5 5 0 117.072 0l-.548.547A3.374 3.374 0 0014 18.469V19a2 2 0 11-4 0v-.531c0-.895-.356-1.754-.988-2.386l-.548-.547z" />
                </svg>
              </div>
            </div>

            <!-- Content -->
            <h3 class="text-xl font-semibold text-text-heading mb-3 text-center">
              Traduction, adaptation et finalisation
            </h3>
            <p class="text-text-muted text-base text-center leading-relaxed">
              Traduction assistée par IA, validation par experts natifs. Pour les vidéos : remontage complet incluant voix, sous-titres et éléments graphiques.
            </p>
          </div>
        </div>

        <!-- Step 3 -->
        <div class="relative process-step">
          <div class="bg-white rounded-3xl shadow-card border border-neutral-100 p-8 card-hover" data-reveal="fade-up" data-reveal-delay="400">
            <!-- Number Badge -->
            <div class="flex justify-center mb-6">
              <div class="w-16 h-16 rounded-2xl bg-gradient-to-br from-primary-400 to-primary-500 flex items-center justify-center" data-reveal="number-pop" data-reveal-delay="400">
                <span class="text-2xl font-bold text-white">3</span>
              </div>
            </div>

            <!-- Icon -->
            <div class="flex justify-center mb-6">
              <div class="w-14 h-14 rounded-xl bg-primary-50 border border-primary-100 flex items-center justify-center">
                <!-- Check/Delivery Icon -->
                <svg class="w-7 h-7 text-primary-500" fill="none" viewBox="0 0 24 24" stroke="currentColor" aria-hidden="true">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z" />
                </svg>
              </div>
            </div>

            <!-- Content -->
            <h3 class="text-xl font-semibold text-text-heading mb-3 text-center">
              Réception des livrables finaux
            </h3>
            <p class="text-text-muted text-base text-center leading-relaxed">
              Sous 72h, vous recevez vos contenus prêts à être déployés sur vos canaux de communication.
            </p>
          </div>
        </div>

      </div>
    </div>

    <!-- Reassurance Message -->
    <div class="mt-16 text-center" data-reveal="scale-in" data-reveal-delay="300">
      <div class="inline-flex items-center gap-3 px-8 py-4 glass rounded-2xl shadow-glass">
        <!-- Badge with gradient -->
        <div class="w-10 h-10 rounded-xl bg-gradient-to-br from-primary-400 to-teal-400 flex items-center justify-center flex-shrink-0">
          <!-- Check Shield Icon for reassurance -->
          <svg class="w-5 h-5 text-white" fill="none" viewBox="0 0 24 24" stroke="currentColor" aria-hidden="true" focusable="false">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z" />
          </svg>
        </div>
        <span class="text-lg md:text-xl font-bold text-text-heading">
          Une prise en charge intégrale. Vous déléguez, nous livrons.
        </span>
      </div>
    </div>
  </div>
</section>
