---
/**
 * ContactSection Component - Apple-Inspired Light Pastel Theme
 *
 * Final conversion section with WhatsApp CTA
 * Implements "Zéro Friction" UX principle
 *
 * @component
 * @warning This component uses an H2 heading and requires a parent H1 on the page
 *          for proper heading hierarchy (WCAG 2.1). Ensure this section is placed
 *          after a section containing an H1 heading (e.g., HeroSection).
 */

import WhatsAppButton from '../ui/WhatsAppButton.astro';
import GeometricBackground from '../ui/GeometricBackground.astro';
import { WHATSAPP_NUMBER, WHATSAPP_MESSAGE_CONTACT } from '../../config';
---

<section
  id="contact"
  aria-labelledby="contact-heading"
  aria-label="Contactez-nous"
  class="relative py-20 md:py-32 px-6 md:px-12 bg-white overflow-hidden"
>
  <!-- Geometric Background Animation -->
  <GeometricBackground intensity="strong" variant="mixed" />

  <!-- Gradient overlay for emphasis -->
  <div class="absolute inset-0 bg-gradient-to-br from-primary-50 to-teal-50 pointer-events-none z-5"></div>

  <div class="relative z-10 max-w-2xl mx-auto text-center">
    <!-- Section Header -->
    <div class="mb-12">
      <h2
        id="contact-heading"
        class="text-3xl md:text-5xl lg:text-6xl font-extrabold gradient-text-hero mb-4"
        data-reveal="blur-in"
      >
        Échangeons sur votre projet
      </h2>
      <p class="text-lg md:text-xl text-text-muted" data-reveal="fade-up" data-reveal-delay="200">
        Présentez-nous vos contenus et vos marchés cibles.<br>
        Nous vous indiquerons comment nous pouvons vous accompagner.
      </p>
    </div>

    <!-- CTA: WhatsApp -->
    <div class="flex justify-center cta-float" data-reveal="fade-up" data-reveal-delay="400">
      <WhatsAppButton
        phoneNumber={WHATSAPP_NUMBER}
        message={WHATSAPP_MESSAGE_CONTACT}
        label="Discuter sur WhatsApp"
        section="contact"
        variant="primary"
      />
    </div>
  </div>
</section>
