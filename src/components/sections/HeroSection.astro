---
/**
 * HeroSection Component - Apple-inspired Light Pastel Theme
 * Mobile-first responsive design with accessibility features
 */
import WhatsAppButton from '../ui/WhatsAppButton.astro';
import GeometricBackground from '../ui/GeometricBackground.astro';
import { WHATSAPP_NUMBER, WHATSAPP_DEFAULT_MESSAGE } from '../../config';
---

<section
  class="relative w-full overflow-hidden bg-gradient-to-b from-primary-50/30 via-white to-teal-50/20"
  aria-label="Hero"
>
  <!-- Floating Gradient Orbs Background -->
  <GeometricBackground intensity="strong" variant="mixed" />

  <!-- Content -->
  <div class="relative z-10 max-w-4xl mx-auto px-6 py-32 md:py-48 lg:py-56 text-center">
    <!-- Headline with gradient text and blur-in reveal -->
    <h1
      class="text-5xl md:text-6xl lg:text-7xl font-extrabold gradient-text-hero leading-tight tracking-tight"
      data-reveal="blur-in"
    >
      Accélérez votre expansion internationale
    </h1>

    <!-- Subheadline with staggered fade-up -->
    <p
      class="text-lg md:text-xl text-text-body mt-6 md:mt-8 max-w-2xl mx-auto leading-relaxed"
      data-reveal="fade-up"
      data-reveal-delay="200"
    >
      Nous traduisons et adaptons l'ensemble de vos contenus — vidéos, formations, PDFs, webinaire de vente, emails, audio... — pour vos marchés cibles. Vous poursuivez votre activité, nous gérons l'intégralité du processus.
    </p>

    <!-- CTA with floating animation -->
    <div
      class="mt-10 md:mt-12 flex justify-center cta-float"
      data-reveal="fade-up"
      data-reveal-delay="400"
    >
      <WhatsAppButton
        phoneNumber={WHATSAPP_NUMBER}
        message={WHATSAPP_DEFAULT_MESSAGE}
        section="hero"
        variant="primary"
      />
    </div>
  </div>
</section>
