---
/**
 * HeroSection Component - Dark Theme with Geometric Animations
 * Mobile-first responsive design with accessibility features
 */
import WhatsAppButton from '../ui/WhatsAppButton.astro';
import GeometricBackground from '../ui/GeometricBackground.astro';
import { WHATSAPP_NUMBER, WHATSAPP_DEFAULT_MESSAGE } from '../../config';
---

<section
  class="relative w-full overflow-hidden bg-dark-base"
  aria-label="Hero"
>
  <!-- Geometric Background Animation -->
  <GeometricBackground intensity="strong" variant="cyan" />

  <!-- Gradient overlay for depth -->
  <div class="absolute inset-0 bg-gradient-to-b from-cyan-500/5 to-transparent pointer-events-none z-5"></div>

  <!-- Content overlay with improved readability -->
  <div class="relative z-10 max-w-4xl mx-auto px-6 py-24 md:py-48 lg:py-64 text-center">
    <!-- Headline with gradient text and blur-in reveal -->
    <h1
      class="text-4xl md:text-5xl lg:text-6xl font-extrabold gradient-text-cyan drop-shadow-lg leading-tight"
      data-reveal="blur-in"
    >
      Accélérez votre expansion internationale
    </h1>

    <!-- Subheadline with staggered fade-up -->
    <p
      class="text-base md:text-xl text-white/95 drop-shadow-md mt-4 md:mt-6 max-w-2xl mx-auto leading-relaxed"
      data-reveal="fade-up"
      data-reveal-delay="200"
    >
      Nous traduisons et adaptons l'ensemble de vos contenus — vidéos, formations, PDFs, webinaire de vente, emails, audio... — pour vos marchés cibles. Vous poursuivez votre activité, nous gérons l'intégralité du processus.
    </p>

    <!-- CTA with breathing animation -->
    <div
      class="mt-8 md:mt-10 flex justify-center cta-float"
      data-reveal="fade-up"
      data-reveal-delay="400"
    >
      <WhatsAppButton
        phoneNumber={WHATSAPP_NUMBER}
        message={WHATSAPP_DEFAULT_MESSAGE}
        section="hero"
        variant="primary"
      />
    </div>
  </div>
</section>
