---
import { generateBreadcrumbJsonLd } from '../../utils/seo';

interface BreadcrumbItem {
  label: string;
  href?: string;
}

interface Props {
  items: BreadcrumbItem[];
}

const { items } = Astro.props;

const jsonLdItems = items.map((item) => ({
  name: item.label,
  url: item.href || '',
}));
---

<nav aria-label="Fil d'Ariane" class="mb-6">
  <ol class="flex flex-wrap items-center gap-1.5 text-sm text-text-muted">
    {items.map((item, index) => (
      <li class="flex items-center gap-1.5">
        {index > 0 && <span aria-hidden="true" class="text-neutral-300">/</span>}
        {item.href ? (
          <a href={item.href} class="hover:text-primary-500 transition-colors">
            {item.label}
          </a>
        ) : (
          <span class="text-text-body font-medium" aria-current="page">
            {item.label}
          </span>
        )}
      </li>
    ))}
  </ol>
</nav>

<script type="application/ld+json" set:html={generateBreadcrumbJsonLd(jsonLdItems)} />
