---
import { formatDate, getReadingTime } from '../../utils/blog';
import CategoryBadge from './CategoryBadge.astro';
import Breadcrumbs from './Breadcrumbs.astro';
import { CATEGORY_LABELS } from '../../config';

interface Props {
  title: string;
  description: string;
  publishDate: Date;
  updatedDate?: Date;
  category: string;
  image: { src: string; alt: string };
  author: { name: string; role?: string };
  readingTime: number;
}

const { title, description, publishDate, updatedDate, category, image, author, readingTime } = Astro.props;
---

<header class="mb-10">
  <Breadcrumbs items={[
    { label: 'Accueil', href: '/' },
    { label: 'Blog', href: '/blog/' },
    { label: CATEGORY_LABELS[category] || category, href: `/blog/categorie/${category}/` },
    { label: title },
  ]} />

  <div class="flex items-center gap-3 mb-4">
    <CategoryBadge category={category} linked />
    <time datetime={publishDate.toISOString()} class="text-sm text-text-muted">
      {formatDate(publishDate)}
    </time>
    <span class="text-sm text-text-muted">&middot; {readingTime} min de lecture</span>
  </div>

  <h1 class="text-3xl md:text-4xl lg:text-5xl font-bold text-text-heading leading-tight mb-4">
    {title}
  </h1>

  <p class="text-lg text-text-muted max-w-3xl mb-8">
    {description}
  </p>

  <div class="rounded-2xl overflow-hidden aspect-[2/1] bg-surface-100">
    <img
      src={image.src}
      alt={image.alt}
      class="w-full h-full object-cover"
      loading="eager"
    />
  </div>
</header>
