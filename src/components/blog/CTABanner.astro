---
import { WHATSAPP_NUMBER, WHATSAPP_MESSAGE_CONTACT } from '../../config';

interface Props {
  text?: string;
}

const { text } = Astro.props;

const displayText = text || 'Besoin d\'aide pour internationaliser vos contenus ?';

const whatsappUrl = `https://wa.me/${WHATSAPP_NUMBER}?text=${encodeURIComponent(WHATSAPP_MESSAGE_CONTACT)}`;
---

<aside class="my-10 p-6 md:p-8 rounded-2xl bg-gradient-to-br from-primary-50 to-teal-50 border border-primary-100">
  <p class="text-lg font-semibold text-text-heading mb-3">
    {displayText}
  </p>
  <p class="text-sm text-text-muted mb-5">
    Notre equipe vous accompagne dans la localisation de tous vos contenus multimedia. Reponse sous 24h.
  </p>
  <a
    href={whatsappUrl}
    target="_blank"
    rel="noopener noreferrer"
    class="btn-primary inline-flex items-center gap-2 text-sm"
  >
    Discuter sur WhatsApp
  </a>
</aside>
