---
import { CATEGORY_LABELS } from '../../config';

interface Props {
  title: string;
  category: string;
  alt: string;
  class?: string;
}

const { title, category, alt, class: className = '' } = Astro.props;

const categoryLabel = CATEGORY_LABELS[category] || category;

const CATEGORY_STYLES: Record<string, { gradient: string; accent: string; icon: string }> = {
  'strategie-internationale': {
    gradient: 'from-indigo-600 via-purple-600 to-indigo-800',
    accent: 'bg-indigo-400/20',
    icon: `<path d="M12 2C6.48 2 2 6.48 2 12s4.48 10 10 10 10-4.48 10-10S17.52 2 12 2zm-1 17.93c-3.95-.49-7-3.85-7-7.93 0-.62.08-1.21.21-1.79L9 15v1c0 1.1.9 2 2 2v1.93zm6.9-2.54c-.26-.81-1-1.39-1.9-1.39h-1v-3c0-.55-.45-1-1-1H8v-2h2c.55 0 1-.45 1-1V7h2c1.1 0 2-.9 2-2v-.41c2.93 1.19 5 4.06 5 7.41 0 2.08-.8 3.97-2.1 5.39z"/>`,
  },
  'localisation-video': {
    gradient: 'from-teal-600 via-cyan-600 to-teal-800',
    accent: 'bg-teal-400/20',
    icon: `<path d="M17 10.5V7c0-.55-.45-1-1-1H4c-.55 0-1 .45-1 1v10c0 .55.45 1 1 1h12c.55 0 1-.45 1-1v-3.5l4 4v-11l-4 4z"/>`,
  },
  'localisation-contenu': {
    gradient: 'from-blue-600 via-sky-600 to-blue-800',
    accent: 'bg-blue-400/20',
    icon: `<path d="M14 2H6c-1.1 0-1.99.9-1.99 2L4 20c0 1.1.89 2 1.99 2H18c1.1 0 2-.9 2-2V8l-6-6zm2 16H8v-2h8v2zm0-4H8v-2h8v2zm-3-5V3.5L18.5 9H13z"/>`,
  },
  'croissance-b2b': {
    gradient: 'from-emerald-600 via-green-600 to-emerald-800',
    accent: 'bg-emerald-400/20',
    icon: `<path d="M16 6l2.29 2.29-4.88 4.88-4-4L2 16.59 3.41 18l6-6 4 4 6.3-6.29L22 12V6z"/>`,
  },
  'guides-sectoriels': {
    gradient: 'from-amber-600 via-orange-600 to-amber-800',
    accent: 'bg-amber-400/20',
    icon: `<path d="M18 2H6c-1.1 0-2 .9-2 2v16c0 1.1.9 2 2 2h12c1.1 0 2-.9 2-2V4c0-1.1-.9-2-2-2zM6 4h5v8l-2.5-1.5L6 12V4z"/>`,
  },
  'seo-international': {
    gradient: 'from-rose-600 via-pink-600 to-rose-800',
    accent: 'bg-rose-400/20',
    icon: `<path d="M15.5 14h-.79l-.28-.27C15.41 12.59 16 11.11 16 9.5 16 5.91 13.09 3 9.5 3S3 5.91 3 9.5 5.91 16 9.5 16c1.61 0 3.09-.59 4.23-1.57l.27.28v.79l5 4.99L20.49 19l-4.99-5zm-6 0C7.01 14 5 11.99 5 9.5S7.01 5 9.5 5 14 7.01 14 9.5 11.99 14 9.5 14z"/>`,
  },
  'outils-et-ressources': {
    gradient: 'from-slate-600 via-gray-600 to-slate-800',
    accent: 'bg-slate-400/20',
    icon: `<path d="M22.7 19l-9.1-9.1c.9-2.3.4-5-1.5-6.9-2-2-5-2.4-7.4-1.3L9 6 6 9 1.6 4.7C.4 7.1.9 10.1 2.9 12.1c1.9 1.9 4.6 2.4 6.9 1.5l9.1 9.1c.4.4 1 .4 1.4 0l2.3-2.3c.5-.4.5-1.1.1-1.4z"/>`,
  },
};

const style = CATEGORY_STYLES[category] || CATEGORY_STYLES['strategie-internationale'];
---

<div
  class={`relative overflow-hidden bg-gradient-to-br ${style.gradient} ${className}`}
  role="img"
  aria-label={alt}
>
  <!-- Geometric pattern overlay -->
  <div class="absolute inset-0 opacity-10">
    <div class="absolute top-6 right-6 w-32 h-32 border-2 border-white rounded-full"></div>
    <div class="absolute top-16 right-16 w-48 h-48 border border-white rounded-full"></div>
    <div class="absolute -bottom-8 -left-8 w-40 h-40 border-2 border-white rounded-full"></div>
    <div class="absolute bottom-12 left-12 w-24 h-24 border border-white rounded-full"></div>
  </div>

  <!-- Subtle dot pattern -->
  <div class="absolute inset-0 opacity-[0.04]" style="background-image: radial-gradient(circle, white 1px, transparent 1px); background-size: 24px 24px;"></div>

  <!-- Content -->
  <div class="relative z-10 flex flex-col justify-between h-full p-6 md:p-8">
    <!-- Category badge + icon -->
    <div class="flex items-center gap-3">
      <div class={`w-10 h-10 rounded-xl ${style.accent} backdrop-blur-sm flex items-center justify-center`}>
        <svg class="w-5 h-5 text-white" fill="currentColor" viewBox="0 0 24 24" set:html={style.icon} />
      </div>
      <span class="text-xs font-semibold uppercase tracking-wider text-white/80">
        {categoryLabel}
      </span>
    </div>

    <!-- Title -->
    <div class="mt-auto pt-6">
      <h4 class="text-white font-bold text-base md:text-lg lg:text-xl leading-snug line-clamp-3 drop-shadow-sm">
        {title}
      </h4>
      <div class="mt-3 flex items-center gap-2">
        <div class="w-8 h-[2px] bg-white/60 rounded-full"></div>
        <span class="text-[10px] font-medium text-white/60 uppercase tracking-widest">Make It Global</span>
      </div>
    </div>
  </div>
</div>
