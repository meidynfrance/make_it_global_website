---
interface Props {
  name: string;
  role?: string;
}

const { name, role } = Astro.props;
---

<div class="flex items-center gap-4 p-5 rounded-2xl bg-surface-50 border border-neutral-200 mt-10">
  <div class="w-12 h-12 rounded-full bg-gradient-to-br from-primary-400 to-teal-400 flex items-center justify-center text-white font-bold text-lg flex-shrink-0">
    {name.charAt(0)}
  </div>
  <div>
    <p class="font-semibold text-text-heading">{name}</p>
    {role && <p class="text-sm text-text-muted">{role}</p>}
  </div>
</div>
