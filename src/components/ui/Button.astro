---
/**
 * Button Component - Apple-Inspired Light Pastel Theme
 * Ensures WCAG AA accessibility with ≥44px touch targets
 */
interface Props {
  variant: 'primary' | 'secondary' | 'outline';
  href: string;
  ariaLabel?: string;
  class?: string;
  'data-section'?: string;
}

const { variant, href, ariaLabel, class: additionalClass, 'data-section': dataSection } = Astro.props;

// Tailwind classes for each variant - Light Pastel Theme
const variantClasses = {
  primary: 'bg-gradient-to-r from-primary-500 to-primary-400 text-white shadow-lg shadow-primary-500/25 hover:shadow-primary-500/35 hover:-translate-y-0.5 focus:ring-primary-400',
  secondary: 'bg-gradient-to-r from-teal-500 to-teal-400 text-white shadow-lg shadow-teal-500/25 hover:shadow-teal-500/35 hover:-translate-y-0.5 focus:ring-teal-400',
  outline: 'border-2 border-primary-200 text-primary-500 hover:bg-primary-50 hover:border-primary-400 focus:ring-primary-400',
};

const baseClasses = 'inline-flex items-center justify-center px-6 py-3 rounded-xl font-semibold text-base transition-all duration-150 focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-offset-white min-h-[44px] active:scale-[0.97]';

// Detect external links (http/https) for security attributes
const isExternal = href.startsWith('http://') || href.startsWith('https://');
---

<a
  href={href}
  class={`${baseClasses} ${variantClasses[variant]} ${additionalClass || ''}`}
  aria-label={ariaLabel}
  target={isExternal ? '_blank' : undefined}
  rel={isExternal ? 'noopener noreferrer' : undefined}
  data-section={dataSection}
>
  <slot />
</a>
