---
/**
 * TestimonialCard Component - Apple-Inspired Light Pastel Theme
 *
 * Displays a client testimonial with visual hierarchy:
 * 1. Result (Most Prominent): Large, bold, gradient metric
 * 2. Quote (Main Content): Client's testimonial in conversational French
 * 3. Client Type (Discreet): Profile type with optional name
 *
 * Props:
 * - quote: Client testimonial quote (2-3 lines max)
 * - result: Highlighted business result (e.g., "CA triplé en 6 mois")
 * - clientType: Client profile (e.g., "Infopreneur", "CEO PME B2B")
 * - clientName (optional): Client name (initials or masked)
 *
 * Usage:
 * <TestimonialCard
 *   result="CA triplé en 6 mois"
 *   quote="Grâce à Make It Global, j'ai pu toucher le marché anglophone sans perdre des mois en traduction."
 *   clientType="Infopreneur"
 *   clientName="M.L."
 * />
 */

interface Props {
  quote: string;
  result: string;
  clientType: string;
  clientName?: string;
}

const { quote, result, clientType, clientName } = Astro.props;
---

<article class="relative bg-white rounded-3xl shadow-card border border-neutral-100 p-6 md:p-8 card-hover">
  <!-- Decorative quotation mark -->
  <span class="absolute top-4 left-6 text-5xl leading-none text-primary-200/60 font-serif select-none pointer-events-none" aria-hidden="true">&ldquo;</span>

  <!-- Result (Visual Prominence) -->
  <p class="result text-3xl md:text-4xl font-bold gradient-text mb-4 mt-4" aria-label={`Résultat: ${result}`} data-counter>
    {result}
  </p>

  <!-- Quote (Main Content) -->
  <blockquote class="quote text-base text-text-body mb-4 italic">
    <p>&laquo;&nbsp;{quote}&nbsp;&raquo;</p>
  </blockquote>

  <!-- Client Type (Discreet) -->
  <footer class="client-info">
    <p class="text-sm text-text-muted font-medium">
      {clientName ? `${clientName}, ` : ''}{clientType}
    </p>
  </footer>
</article>
