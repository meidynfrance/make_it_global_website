---
/**
 * GeometricBackground Component
 *
 * Apple-inspired floating gradient orbs for light pastel theme.
 * Creates a premium, soft background with large blurred gradient circles
 * that float slowly across the section.
 *
 * Props:
 * - intensity: 'subtle' | 'medium' | 'strong' - Opacity multiplier
 * - variant: 'primary' | 'teal' | 'mixed' | 'warm' - Color scheme
 */

interface Props {
  intensity?: 'subtle' | 'medium' | 'strong';
  variant?: 'primary' | 'teal' | 'mixed' | 'warm';
}

const { intensity = 'medium', variant = 'mixed' } = Astro.props;

// Opacity multiplier based on intensity
const opacityMap = {
  subtle: 0.5,
  medium: 1,
  strong: 1.5,
};

const opacityMultiplier = opacityMap[intensity];

// Orb configurations per variant
const variantOrbs = {
  primary: [
    { class: 'orb-primary', size: 480, top: '-8%', left: '-5%', delay: '0s' },
    { class: 'orb-primary', size: 350, top: '55%', right: '-8%', delay: '3s' },
    { class: 'orb-primary', size: 280, top: '30%', left: '25%', delay: '6s' },
    { class: 'orb-primary', size: 400, bottom: '-10%', left: '50%', delay: '9s' },
  ],
  teal: [
    { class: 'orb-teal', size: 420, top: '-5%', right: '10%', delay: '0s' },
    { class: 'orb-teal', size: 320, top: '50%', left: '-6%', delay: '4s' },
    { class: 'orb-teal', size: 380, bottom: '-8%', right: '20%', delay: '7s' },
    { class: 'orb-teal', size: 250, top: '20%', left: '40%', delay: '2s' },
  ],
  mixed: [
    { class: 'orb-primary', size: 450, top: '-10%', left: '-5%', delay: '0s' },
    { class: 'orb-teal', size: 380, top: '40%', right: '-8%', delay: '4s' },
    { class: 'orb-primary', size: 300, bottom: '-5%', left: '30%', delay: '7s' },
    { class: 'orb-teal', size: 260, top: '15%', left: '55%', delay: '2s' },
    { class: 'orb-primary', size: 200, bottom: '10%', right: '15%', delay: '10s' },
  ],
  warm: [
    { class: 'orb-rose', size: 420, top: '-8%', right: '5%', delay: '0s' },
    { class: 'orb-amber', size: 360, top: '50%', left: '-6%', delay: '3s' },
    { class: 'orb-rose', size: 280, bottom: '-5%', left: '40%', delay: '6s' },
    { class: 'orb-amber', size: 320, top: '20%', left: '20%', delay: '9s' },
    { class: 'orb-rose', size: 220, bottom: '15%', right: '10%', delay: '5s' },
  ],
};

const orbs = variantOrbs[variant];
---

<div class="geometric-background" aria-hidden="true" style={`opacity: ${opacityMultiplier};`}>
  {orbs.map((orb) => {
    const positionStyle = [
      orb.top !== undefined && `top: ${orb.top}`,
      orb.bottom !== undefined && `bottom: ${orb.bottom}`,
      orb.left !== undefined && `left: ${orb.left}`,
      orb.right !== undefined && `right: ${orb.right}`,
      `width: ${orb.size}px`,
      `height: ${orb.size}px`,
      `animation-delay: ${orb.delay}`,
    ].filter(Boolean).join('; ');

    return (
      <div
        class={`orb ${orb.class}`}
        style={positionStyle}
      />
    );
  })}
</div>

<style>
  .geometric-background {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    overflow: hidden;
    pointer-events: none;
    z-index: 0;
  }
</style>
